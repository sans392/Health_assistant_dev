# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

# LLM модели по ролям (Phase 2)
# Если не задано — используется OLLAMA_MODEL для всех ролей
# LLM_INTENT_MODEL=qwen2.5:7b
# LLM_SAFETY_MODEL=qwen2.5:7b
# LLM_RESPONSE_MODEL=qwen2.5:14b
# LLM_PLANNER_MODEL=qwen2.5:32b

# Эмбеддинги (Phase 2)
EMBEDDING_MODEL=nomic-embed-text

# ChromaDB (Phase 2)
CHROMA_PATH=/app/data/chroma

# База данных
DB_PATH=/app/data/health_assistant.db

# Приложение
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# Админ-панель (Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
